# Copy to .env and fill in. Never commit real secrets.

# OpenAI-compatible API (OpenAI / OpenRouter / moon-bridge / local)
LLM_API_KEY=sk-...
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini

# IBKR TWS / IB Gateway
# Paper: 7497 (TWS) or 4002 (Gateway)
# Live:  7496 (TWS) or 4001 (Gateway)
IBKR_HOST=127.0.0.1
IBKR_PORT=7497
IBKR_CLIENT_ID=17

# Safety: keep true until you explicitly want live orders
DRY_RUN=true
